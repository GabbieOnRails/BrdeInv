{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Business information for the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "businessName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string" },
        "currency": { "type": "string" },
        "taxRate": { "type": "number" },
        "paymentInstructions": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "businessName"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Invoice or Receipt document",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["invoice", "receipt"] },
        "invoiceNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerAddress": { "type": "string" },
        "items": { "type": "array" },
        "taxRate": { "type": "number" },
        "taxAmount": { "type": "number" },
        "subtotal": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "pending", "partial", "paid", "overdue"] },
        "notes": { "type": "string" },
        "templateId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment record for an invoice",
      "type": "object",
      "properties": {
        "invoiceId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "method": { "type": "string", "enum": ["cash", "transfer", "card", "other"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User business profile"
    },
    "/users/{userId}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "User invoices"
    },
    "/users/{userId}/invoices/{invoiceId}/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payments made against an invoice"
    }
  }
}
